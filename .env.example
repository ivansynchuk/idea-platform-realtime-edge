# Shared HS256 secret — MUST be identical to the monolith's JWT_SECRET, or
# token validation will fail.
JWT_SECRET=change-me-to-match-the-backend

# Frontend origin allowed by Socket.IO CORS.
FRONTEND_URL=http://localhost:5173

# Redis bridge to the NestJS monolith (Phase 3 — not wired yet).
REDIS_URL=redis://localhost:6379

# Port for the uvicorn server (used by the run command).
PORT=3002
